public class EvenSum {
    public static void main(String[] args) {

        int num = 10; // runtime value
        int sum = 0;
        boolean first = true;

        for (int i = 2; i <= num; i += 2) {
            if (!first) {
                System.out.print(",");
            }
            System.out.print(i);
            sum += i;
            first = false;
        }

        System.out.println();
        System.out.println(sum);
    }
}
