public class EvenSum {
    public static void main(String[] args) {
        int num = 10; // pre-defined variable, runtime may change this
        int sum = 0;

        for (int i = 2; i <= num; i += 2) {
            System.out.print(i);
            sum += i;

            if (i + 2 <= num) {
                System.out.print(",");
            }
        }

        System.out.println();
        System.out.println(sum);
    }
}
