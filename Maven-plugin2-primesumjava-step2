public class PrimeSum {

    public static boolean isPrime(int num) {
        if (num < 2) return false;
        for (int i = 2; i <= Math.sqrt(num); i++) {
            if (num % i == 0) return false;
        }
        return true;
    }

    public static int sumOfPrimes(int maxNum) {
        // Return 0 if maxNum is less than or equal to zero
        if (maxNum <= 0) {
            return 0;
        }

        int sum = 0;
        for (int i = 2; i <= maxNum; i++) {
            if (isPrime(i)) {
                sum += i;
            }
        }
        return sum;
    }

    public static void main(String[] args) {
        int maxNum = 10; // example value
        System.out.println("Sum of primes up to " + maxNum + ": " + sumOfPrimes(maxNum));
    }
}
