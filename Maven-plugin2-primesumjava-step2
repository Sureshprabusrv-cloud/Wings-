public class EvenSum {
    public static void main(String[] args) {
        // 'num' is likely pre-defined or provided. 
        // If testing locally, you can use: int num = 10;
        
        int sum = 0;
        StringBuilder output = new StringBuilder();

        for (int i = 2; i <= num; i += 2) {
            output.append(i);
            sum += i;
            
            // Only add a comma if it's not the last even number
            if (i + 2 <= num) {
                output.append(",");
            }
        }

        System.out.println(output.toString());
        System.out.println(sum);
    }
}
