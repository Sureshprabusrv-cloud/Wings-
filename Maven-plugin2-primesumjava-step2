package javaApp;

public class PrimeSum {

    public static boolean isPrime(int num) {
        if (num < 2) return false;
        for (int i = 2; i <= Math.sqrt(num); i++) {
            if (num % i == 0) return false;
        }
        return true;
    }

    public static long primesum(int maxNum) {
        if (maxNum <= 0) {
            return 0;
        }
        long sum = 0;
        for (int i = 2; i <= maxNum; i++) {
            if (isPrime(i)) {
                sum += i;
            }
        }
        return sum;
    }
}
