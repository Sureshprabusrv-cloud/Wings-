package javaApp;

public class PrimeSum {

    public static long primesum(int maxNum) {
        long sum = 0;

        if (maxNum <= 0) {
            return 0;
        }

        for (int i = 2; i < maxNum; i++) {   // strictly less than maxNum
            boolean isPrime = true;

            for (int j = 2; j < i; j++) {
                if (i % j == 0) {
                    isPrime = false;
                    break;
                }
            }

            if (isPrime) {
                sum += i;
            }
        }

        return sum;
    }

    public static void main(String[] args) {
        int maxNum = 0;

        if (args.length > 0) {
            maxNum = Integer.parseInt(args[0]);
        }

        System.out.println(primesum(maxNum));
    }
}
