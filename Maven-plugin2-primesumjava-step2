package com.example;

public class PrimeSum {

    public static int sumOfPrimes(int maxNum) {
        if (maxNum <= 0) {
            return 0;
        }

        int sum = 0;
        for (int i = 2; i <= maxNum; i++) {
            if (isPrime(i)) {
                sum += i;
            }
        }
        return sum;
    }

    private static boolean isPrime(int n) {
        if (n < 2) return false;
        for (int i = 2; i <= Math.sqrt(n); i++) {
            if (n % i == 0) return false;
        }
        return true;
    }

    public static void main(String[] args) {
        int maxNum = 10; // change as needed
        System.out.println("Sum of primes up to " + maxNum + ": " + sumOfPrimes(maxNum));
    }
}
