---
- name: Create simplefile.txt
  file:
    path: /home/user/simplefile.txt
    state: touch

- name: Check if file exists in test folder
  stat:
    path: /home/user/test/simplefile.txt
  register: file_check

- name: Move simplefile.txt to /home/user/test
  command: mv /home/user/simplefile.txt /home/user/test/simplefile.txt
  when: not file_check.stat.exists
